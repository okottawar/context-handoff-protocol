# ── CHP environment for HuggingFace Spaces ───────────────────────────────────
# Add these as Space Secrets (Settings → Variables and Secrets → New secret)
# DO NOT commit this file with real tokens.

# ── Providers ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence_transformer
ST_MODEL=all-MiniLM-L6-v2

LLM_PROVIDER=hf_inference
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ── HF Inference model options (pick one) ─────────────────────────────────────
# Fast, no token needed (public model):
HF_LLM_MODEL=HuggingFaceH4/zephyr-7b-beta

# Better quality, needs HF token with model access:
# HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# HF_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ── Database ──────────────────────────────────────────────────────────────────
# /data persists across restarts on HF Spaces with Persistent Storage addon.
# Without the addon, /data is ephemeral — reset on each restart.
DATABASE_URL=sqlite+aiosqlite:////data/chp.db

# ── App ───────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860

# ── Optional connectors ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
GITHUB_TOKEN=

# ── Demo dataset ─────────────────────────────────────────────────────────────
# Leave blank to use the bundled backend/data/synthetic_dataset.json
DATASET_PATH=

# ── Pipeline ──────────────────────────────────────────────────────────────────
INGEST_DAYS_BACK=30
HDBSCAN_MIN_CLUSTER_SIZE=2
STALENESS_HALFLIFE_DAYS=7
MAX_THREADS_PER_BRIEF=8
