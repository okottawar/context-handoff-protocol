# Active providers 
# Swap these strings to change the model backend. No code changes needed.
# EMBEDDING_PROVIDER options: "sentence_transformer" | "ollama"
# LLM_PROVIDER options:       "ollama" | "openai_compat"

EMBEDDING_PROVIDER=sentence_transformer
LLM_PROVIDER=ollama

# Sentence Transformers (local, fully offline) 
# Any model name from https://www.sbert.net/docs/pretrained_models.html
ST_MODEL=all-MiniLM-L6-v2

# Ollama (local inference server) 
# Install: https://ollama.com  |  then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI-compatible endpoint (LM Studio, LocalAI, vLLM, etc.) ──
# Works with any server exposing the /v1/chat/completions endpoint
OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_API_KEY=not-needed
OPENAI_COMPAT_MODEL=local-model

# Connectors 
# Leave blank to use the built-in Mock connector (no tokens required)
SLACK_BOT_TOKEN=
GITHUB_TOKEN=

# Demo dataset 
# Leave blank to use the bundled backend/data/synthetic_dataset.json
# (4 users, 58 events, 13 work threads across Slack/GitHub/Notion/Email/Calendar)
DATASET_PATH=

# Pipeline tuning 
INGEST_DAYS_BACK=30          # How many days of history to pull
HDBSCAN_MIN_CLUSTER_SIZE=2   # Min events to form a thread
STALENESS_HALFLIFE_DAYS=7    # Recency decay half-life
MAX_THREADS_PER_BRIEF=8      # Cap threads in generated brief

# App 
DATABASE_URL=sqlite+aiosqlite:///./chp.db
HOST=0.0.0.0
PORT=8000
